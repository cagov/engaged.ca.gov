{% set active_page = 'home' %}
{% extends "layout.njk" %}
{% block content %}

<section id="hero" class="hero">
  <div class="container banner-flex">
    <engca-banner-content>
      {{ modules.hero.content | safe }}
      <a href="{{ "/ai-impact/" | locale_url }}" data-appearance="button" data-theme="orange">
        {{ modules.hero.buttonText_learnmore }}
      </a>
    </engca-banner-content>
    <img src="/public/images/hero-bubbles.png" aria-hidden="true" class="desktop-only" alt="{{ 'home-alt-header' | i18n }}" />
  </div>
</section>
<section id="about" class="action-hero">
  <div class="container banner-flex">
    <engca-banner-content>
      {{ modules.about.content | safe }}
      <a href="{{ "/about" | locale_url }}" data-appearance="button" data-theme="off-white">
        {{ modules.about.buttonText }}
      </a>
    </engca-banner-content>
    <img src="/public/images/about-bubbles.svg" aria-hidden="true" class="desktop-only" alt="{{ 'home-alt-header-about' | i18n }}" />
  </div>
</section>

<section id="homepage-engagements" class="action-hero">
  <div class="container">
    {{ modules.homepage_engagements.content | safe }}
    <div class="engagements-grid">
      <article class="engagement-card">
        <img src="/public/images/project_ai.jpg" alt="{{ modules.homepage_engagements.ai_title }}" />
        <div class="engagement-card-body">
          <span class="engagement-status">{{ modules.homepage_engagements.openText }}</span>
          <h3>{{ modules.homepage_engagements.ai_title }}</h3>
          <p>{{ modules.homepage_engagements.ai_description }}</p>
          <a href="{{ "/ai-impact/" | locale_url }}" data-appearance="button" data-theme="orange">
            {{ modules.hero.buttonText_learnmore }}
          </a>
        </div>
      </article>
      <article class="engagement-card">
        <img src="/public/images/project_e3.jpg" alt="{{ modules.homepage_engagements.e3_title }}" />
        <div class="engagement-card-body">
          <span class="engagement-status">{{ modules.homepage_engagements.statusText }}</span>
          <h3>{{ modules.homepage_engagements.e3_title }}</h3>
          <p>{{ modules.homepage_engagements.e3_description }}</p>
          <a href="{{ "/stateemployees/efficiency/" | locale_url }}" data-appearance="button" data-theme="orange">
            {{ modules.hero.buttonText_results }}
          </a>
        </div>
      </article>
      <article class="engagement-card">
        <img src="/public/images/project_lafires.jpg" alt="{{ modules.homepage_engagements.lafires_title }}" />
        <div class="engagement-card-body">
          <span class="engagement-status">{{ modules.homepage_engagements.statusText }}</span>
          <h3>{{ modules.homepage_engagements.lafires_title }}</h3>
          <p>{{ modules.homepage_engagements.lafires_description }}</p>
          <a href="{{ "/lafires-recovery/action-plan" | locale_url }}" data-appearance="button" data-theme="orange">
            {{ modules.hero.buttonText_actionplan }}
          </a>
        </div>
      </article>
    </div>
  </div>
</section>
<section id="how-it-works" class="action-hero">
  <div class="container">
    <h2>{{ 'how-it-works' | i18n }}</h2>
    <ol class="hiw">
      <li class="hiw-step-1">
        <img src="/public/images/how-it-works-public.svg" alt="{{ 'how-it-works-alt-1' | i18n }}" />
        <span class="hiw-text">{{ 'how-it-works-step-1' | i18n }}</span>
        <span class="hiw-arrow"></span>
      </li>
      <li class="hiw-step-2">
        <img src="/public/images/how-it-works-state.svg" alt="{{ 'how-it-works-alt-2' | i18n }}" />
        <span class="hiw-text">{{ 'how-it-works-step-2' | i18n }}</span>
        <span class="hiw-arrow"></span>
      </li>
      <li class="hiw-step-3">
        <img src="/public/images/how-it-works-public.svg" alt="{{ 'how-it-works-alt-1' | i18n }}" />
        <span class="hiw-text">{{ 'how-it-works-step-3' | i18n }}</span>
        <span class="hiw-arrow"></span>
      </li>
      <li class="hiw-step-4">
        <img src="/public/images/how-it-works-state.svg" alt="{{ 'how-it-works-alt-2' | i18n }}" />
        <span class="hiw-text">{{ 'how-it-works-step-4' | i18n }}</span>
      </li>
    </ol>
  </div>
</section>
<section id="sign-up" class="action-form">
  <div class="container form-flex">
    <img src="/public/images/bubble-cluster-1.svg" class="signup-cluster-1" aria-hidden="true" alt="" />
    <img src="/public/images/bubble-cluster-2.svg" class="signup-cluster-2" aria-hidden="true" alt="" />

<!-- begin replacement form -->

{{ modules.sign_up.content | safe }}
{# <h2>{{ 'join-the-conversation' | i18n }}</h2>

  <p>{{ modules.sign_up'join-the-conversation-form-label' | i18n }}</p> #}

  <a href="https://join.engaged.ca.gov/" data-appearance="button" data-theme="orange">
    {{ modules.sign_up.buttonText }}
  </a>
<!-- end replacement form -->



    {# {% include "form.njk" %} #}
  </div>
</section>
<section id="partners" class="action-hero">
  <div class="container">
    {{ modules.partners.content | safe }}
    <engca-partner-flex>
      <img src="/public/images/carnegie.svg" alt="Carnegie Endowment for International Peace" />
      <img src="/public/images/liberty-color.png" alt="Project Liberty Institute" />
      <img src="/public/images/berggruen.svg" alt="Berggruen Institute" />
      <img src="/public/images/stanford.png" alt="Stanford Deliberative Democracy Lab, Center on Democracy, Development and the Rule of Law" />
      <img src="/public/images/berkman-klein.svg" alt="Berkman Klein Center for internet & society at Harvard University" />
      <img src="/public/images/ppic.svg" alt="PPIC" />
      <img src="/public/images/sff.png" alt="San Francisco Foundation" />
      <img src="/public/images/american-public-trust.png" alt="The American Public Trust" />
      <img src="/public/images/public-good-group.png" alt="Public Good Group" />
      <img src="/public/images/goldman-school.svg" alt="UC Berkeley Center on Civility & Democratic Engagement, Goldman School of Public Policy, Founded by the Class of 1968" />
      <img src="/public/images/kapor-center.svg" alt="Kapor Center" />
    </engca-partner-flex>
  </div>
</section>

{% endblock %}